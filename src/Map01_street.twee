<<passTime 20 "no_hygiene">><<set $hp to Math.max(0, $hp - 1)>><<gainSkillExp "awareness" 0.1>>
<<go "返回" "圖書館" 0>>

:: 知識書籍 [library safe]
<<passTime 20 "no_hygiene">><<set $hp to Math.max(0, $hp - 1)>><<gainSkillExp "knowledge" 0.2>>
<<go "返回" "圖書館" 0>>

:: 靈巧書籍 [library safe]
<<passTime 20 "no_hygiene">><<set $hp to Math.max(0, $hp - 1)>><<gainSkillExp "dexterity" 0.2>>
<<go "返回" "圖書館" 0>>

:: 科技書籍 [library safe]
<<passTime 20 "no_hygiene">><<set $hp to Math.max(0, $hp - 1)>><<gainSkillExp "tech" 0.2>>
<<go "返回" "圖書館" 0>>

