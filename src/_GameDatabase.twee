:: GameDatabase [script]
/*
    遊戲的「靜態資料庫」。規則程式放在其他檔案；可編輯內容集中在這裡。
    ID（例如 tea、alice）一旦發行存檔後不要改名；顯示名稱則可隨時在 locales 裡修改。
*/
/*
    ╔══════════════════════════════════════════════╗
    ║                遊戲平衡設定區                 ║
    ║  想調整難度時，優先只修改這一區的數字。         ║
    ╚══════════════════════════════════════════════╝

    這裡放「規則數字」：初始狀態、時間消耗、工作、事件機率等。
    物品的售價與效果則留在下方 gameDatabase.items，因為它們屬於個別物品資料。
*/
setup.balance = {
    /* 改動這一區時，也請同步更新「遊戲狀態與平衡規格.md」與計算機。 */
    saveVersion: 8,
    player: {
        /* 開局金額只夠撐過最初幾天；第 7 天前需要開始工作。 */
        startMoney: 500,
        stats: {
            hp: { start: 80, max: 100 },
            horny: { start: 15, max: 100 },
            luck: { start: 50, max: 100 },
            mood: { start: 70, max: 100 },
            satiety: { start: 80, max: 100 },
            hygiene: { start: 75, max: 100 }
        }
    },
    /* 800 / 7 約為每天 114 元，是前期最重要的經濟壓力。 */
    rent: {
        intervalDays: 7,
        amount: 800,
        graceDays: 3,
        dailyAffectionPenalty: 5,
        evictionAffectionPenalty: 35
    },
    housing: {
        /* 全域聲望過低時，警察房東喬爾會主動解除租約。 */
        reputationEvictionAt: -35,
        highJoelAffectionAt: 30
    },
    time: {
        minutesPerTick: 60,
        satietyLossPerTick: 3,
        hornyGainPerTick: 3,
        hpLossPerTick: 1,
        hygieneLossPerTick: 2
    },
    /* 睡 7 小時回 42 體力；每天工作 4 小時約剛好維持體力，健身需要額外安排。 */
    sleep: { minutesPerStep: 30, hpGainPerStep: 3 },
    skills: { maxLevel: 10, expBase: 100, fitnessHpMaxGain: 6 },
    /* 4 小時工作 = 220；扣兩份泡麵 100 後，約剛好覆蓋每天房租準備金。 */
    cafeWork: { hourlyPay: 55, hpCost: 7, hygieneCost: 5, moodCost: 2 },
    gym: {
        membershipFee: 300,
        membershipDays: 7,
        visitFee: 80,
        workoutMinutes: 20,
        fitnessExpPerWorkout: 10,
        hpCost: 6,
        satietyCost: 5,
        hygieneCost: 8,
        showerMinutes: 20
    },
    /* 公園跑步免費但效率低；目的是讓玩家用較少健身經驗換取靈巧的起步。 */
    parkRun: { minutes: 25, fitnessExp: 1, dexterityExp: 2, satietyCost: 3, hygieneCost: 5 },
    /* 公園休息是短暫恢復，不應比睡覺有效率；仍會正常流逝時間與累積自然消耗。 */
    parkRest: { minutes: 15, hpRestore: 1, moodRestore: 2 },
    /* 聲望只在角色資訊以文字顯示；新增階段時從低到高填入即可。 */
    reputation: {
        minimum: -100,
        maximum: 100,
        tiers: [
            { maximum: -60, text: "你在這個世界裡惡名昭彰。" },
            { maximum: -20, text: "你在這個世界裡風評不佳。" },
            { maximum: 19, text: "沒有多少人認識你。" },
            { maximum: 59, text: "你在這個世界小有名氣。" },
            { maximum: 100, text: "你很受歡迎，大家都喜歡你。" }
        ]
    },
    /*
        深夜便利商店搶劫：有高風險的一次性現金選項，不能取代正常工作。
        初始 Lv.1 健身、幸運 50 時成功率為 34%；最高不超過 85%。
    */
    convenienceRobbery: {
        startHour: 0,
        endHour: 5,
        cooldownMinutes: 360,
        baseChance: 15,
        fitnessLevelWeight: 6,
        luckWeight: 25,
        minimumChance: 25,
        maximumChance: 85,
        minutes: 20,
        guaranteedReward: 140,
        luckyBonusMinimum: 60,
        luckyBonusMaximum: 160,
        failureHpDamage: 20,
        failureMoodDamage: 15,
        reputationLoss: 8
    },
    /*
        心情不直接扣血，而是改變「有效幸運」。不修改 $luck 本身，
        因此不會和限時幸運道具的原始數值互相覆蓋。
    */
    moodLuck: {
        lowMoodMaximumPercent: 20,
        highMoodMinimumPercent: 80,
        lowMoodLuckModifier: -20,
        highMoodLuckModifier: 10
    },
    /*
        三段式飢餓壓力：低飽食先提醒，嚴重飢餓會隨時間失去體力。
        歸零時保留少量「每次行動」扣血，讓玩家一按按鈕就知道自己餓壞了。
    */
    survival: {
        warningPercent: 25,
        criticalPercent: 10,
        criticalHungerHpLossPerHour: 1,
        starvationHpLossPerHour: 3,
        starvationHpCostPerAction: 1,
        starvationSleepRecoveryMultiplier: 0.5
    },
    robber: {
        dayChance: 5,
        nightChance: 30,
        minimumChance: 1,
        luckReductionPerPoint: 0.4,
        cooldownMinutes: 120,
        moodPenalty: 5,
        paymentDemand: 100,
        noMoneyAttackChance: 50,
        noMoneyHpDamage: 10,
        noMoneyMoodDamage: 10,
        escapeHpCost: 5,
        guaranteedEscapeHp: 50,
        combat: {
            baseChance: 10,
            hpWeight: 20,
            fitnessLevelWeight: 5,
            dexterityLevelWeight: 5,
            luckWeight: 20,
            minimumChance: 15,
            maximumChance: 90,
            victoryMoodGain: 20,
            victoryMoneyReward: 800,
            defeatMoodPenalty: 35
        }
    }
};

setup.gameDatabase = {
    version: 1,
    defaultLanguage: "zh-TW",

