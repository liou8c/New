        criminology_security: { name: "犯罪學與安全研究系", majorSkill: "knowledge", minorSkill: "dexterity", description: "研究犯罪、調查與安全實務。" }
    },
    /*
        正式場所與工作的衛生規則。
        新增場所時，只要新增一個 ID 與 entry／work 的規則，不需要複製判斷程式。
        minimum 是「低於此值」才禁止；例如 20 代表衛生 20 仍可通過。
    */
    venueRules: {
        cafe: {
            name: "咖啡廳",
            hygiene: {
                entry: {
                    minimum: 10,
                    message: "你正要走進咖啡廳，卻注意到自己滿身汗味，你感覺自己很邋遢，不適合走進這裡。",
                    returnPassage: "街道",
                    returnLabel: "返回街道"
                },
                work: {
                    minimum: 15,
                    message: '@@.npc-winley;溫莉@@看了看你凌亂的儀容，委婉地說：@@.npc-winley;「今天先去洗個澡吧，整理好再來上班。」@@',
                    returnPassage: "咖啡廳",
                    returnLabel: "返回咖啡廳"
                }
            }
        },
        university: {
            name: "大學",
            /* 大學白天正常開放；非開放時間只能嘗試開鎖。 */
            access: {
                entryPassage: "大學",
                returnPassage: "市區",
                returnLabel: "返回市區",
                openDays: [1, 2, 3, 4, 5],
                openHour: 7,
                closeHour: 19,
                afterHoursMessage: "校門已經關上，側門的門鎖看起來或許能用工具打開。",
                lockpick: {
                    /* 初始靈巧 Lv.1、有效幸運 50 時成功率為 28%；最高 85%。 */
                    baseChance: 20,
                    difficulty: 15,
                    dexterityLevelWeight: 10,
                    luckWeight: 0.25,
                    minimumChance: 5,
                    maximumChance: 85,
                    minutes: 15,
                    attemptCooldownMinutes: 60,
                    guardBaseChance: 35,
                    guardDexterityReductionPerLevel: 4,
                    guardLuckReduction: 0.15,
                    guardMinimumChance: 10,
                    guardMaximumChance: 75,
                    caughtReputationLoss: 6,
                    successMessage: "你避開校園巡邏的視線，撬開側門的門鎖，悄悄溜進校園。",
                    failedMessage: "門鎖發出刺耳的金屬摩擦聲。你只好先收起工具，等風頭過去再說。",
                    caughtMessage: "警衛循著聲音趕來，嚴厲地將你趕出校門，並警告今天不准再靠近。",
                    lockoutMessage: "校門口的警衛顯然記得你。今天再靠近，只會讓事情變得更糟。",
                    cooldownMessage: "側門附近還有人影巡邏。你得先讓剛才的聲響被夜色掩蓋。"
                }
            },
            /*
                每次上課單獨收費，而不是固定週期學費。
                主修經驗約為副修的 2.4 倍；兩項技能滿級後不再允許付費上課。
            */
            education: {
                classMinutes: 60,
                tuitionPerClass: 30,
                majorExp: 12,
                minorExp: 5,
                /* 入學滿幾天後才可在學生服務中心申請轉系。日後可在 canChangeMajor() 加入考試等條件。 */
                majorChangeWaitDays: 7
            }
        }
    }
};

/*
    取得「這次判定要使用的幸運」。
    $luck 是玩家本來的幸運（會存檔）；心情帶來的加減成只是即時效果，
    所以心情跨過門檻時會立刻生效／解除，也不需要建立額外的限時效果資料。
*/
setup.getMoodLuckModifier = function () {
    const state = State.variables;
    const rule = setup.balance.moodLuck;
    const moodPercent = state.moodMax > 0 ? (state.mood / state.moodMax) * 100 : 0;
    if (moodPercent <= rule.lowMoodMaximumPercent) { return rule.lowMoodLuckModifier; }
    if (moodPercent >= rule.highMoodMinimumPercent) { return rule.highMoodLuckModifier; }
    return 0;
};

setup.getEffectiveLuck = function () {
    const state = State.variables;
    return Math.max(0, Math.min(state.luckMax, state.luck + setup.getMoodLuckModifier()));
};

setup.getMoodLuckStatus = function () {
    const modifier = setup.getMoodLuckModifier();
    if (modifier < 0) { return "心情低落：幸運 " + modifier; }
    if (modifier > 0) { return "心情愉快：幸運 +" + modifier; }
    return "";
};

/* 將數值聲望翻譯成角色資訊可直接顯示的文字。 */
setup.getReputationDescription = function () {
    const rule = setup.balance.reputation;
    const reputation = Math.max(rule.minimum, Math.min(rule.maximum, Number(State.variables.reputation) || 0));
    const tier = rule.tiers.find(function (item) { return reputation <= item.maximum; });
    return tier ? tier.text : rule.tiers[rule.tiers.length - 1].text;
};

setup.getPlayerGenderName = function () {
    const gender = setup.gameDatabase.characterGenders[State.variables.playerGender];
    return gender ? gender.name : "未設定";
};

/* 角色建立與大學課程共用的顯示／資料工具。 */
setup.skillNames = {
    fitness: "健身", charm: "魅力", awareness: "意識", knowledge: "知識",
    dexterity: "靈巧", tech: "科技", creative: "創作", cooking: "料理",
    oral: "口部", manual: "手部", vaginal: "陰道", anal: "肛門"
};

setup.getSkillName = function (skillId) {
    return setup.skillNames[skillId] || skillId;
};

setup.getMajor = function (majorId) {
    return setup.gameDatabase.majors[majorId] || null;
};

setup.getMajorName = function () {
    const major = setup.getMajor(State.variables.majorId);
    return major ? major.name : "未選擇科系";
};

/* 轉系資格集中在這裡；日後新增考試、聲望或費用門檻時，只需擴充這個函式。 */
setup.canChangeMajor = function () {
    const state = State.variables;
    return !!state.majorChangeAvailableAt && !!state.gameDate && state.gameDate >= state.majorChangeAvailableAt;
};

setup.getUniversityClassPlan = function () {
    const state = State.variables;
    const major = setup.getMajor(state.majorId);
    const university = setup.gameDatabase.venueRules.university;
    const education = university && university.education;
    if (!major || !education || !state.skills) { return null; }

    const maxLevel = state.skillMaxLevel || setup.balance.skills.maxLevel;
    return {
        majorName: major.name,
        majorSkill: major.majorSkill,
        minorSkill: major.minorSkill,
        majorExp: state.skills[major.majorSkill].level < maxLevel ? education.majorExp : 0,
        minorExp: state.skills[major.minorSkill].level < maxLevel ? education.minorExp : 0,
        classMinutes: education.classMinutes,
        tuition: education.tuitionPerClass
    };
};

setup.getMinutesUntilVenueClose = function (venueId) {
    const rule = setup.getVenueAccessRule(venueId);
    const date = State.variables.gameDate;
    if (!rule || !date || !setup.isVenueOpenNow(venueId)) { return 0; }
    return Math.max(0, (rule.closeHour - date.getHours()) * 60 - date.getMinutes());
};

/*
    正式場所／工作場所的共用衛生檢查。
    venueId 是場所 ID（例如 cafe）；context 是 entry 或 work。
    沒有設定規則的場所一律通過，方便逐步新增內容。
*/
setup.getVenueHygieneRule = function (venueId, context) {
    const venue = setup.gameDatabase.venueRules[venueId];
    return venue && venue.hygiene && venue.hygiene[context] ? venue.hygiene[context] : null;
};

setup.canUseVenue = function (venueId, context) {
    const rule = setup.getVenueHygieneRule(venueId, context);
    return !rule || State.variables.hygiene >= rule.minimum;
};

/* 記住本次被拒絕的場所，讓共用 passage 能讀取各場所不同的事件文字。 */
setup.setVenueHygieneDenied = function (venueId, context) {
    State.variables.venueAccessDenied = { venueId: venueId, context: context };
};

/* 以下是所有「開放時間／開鎖進入」場所共用的工具。 */
setup.getVenueAccessRule = function (venueId) {
    const venue = setup.gameDatabase.venueRules[venueId];
    return venue && venue.access ? venue.access : null;
};

setup.getGameDateKey = function () {
    const date = State.variables.gameDate;
    return date.getFullYear() + "-" + String(date.getMonth() + 1).padStart(2, "0") + "-" + String(date.getDate()).padStart(2, "0");
};

setup.isVenueOpenNow = function (venueId) {
    const rule = setup.getVenueAccessRule(venueId);
    const date = State.variables.gameDate;
    if (!rule || !date) { return true; }
    return rule.openDays.includes(date.getDay()) && date.getHours() >= rule.openHour && date.getHours() < rule.closeHour;
};

setup.isVenueLockedOutToday = function (venueId) {
    const lockouts = State.variables.venueDailyLockouts || {};
    return lockouts[venueId] === setup.getGameDateKey();
};

setup.getVenueCooldownRemaining = function (venueId) {
    const cooldowns = State.variables.venueAccessCooldowns || {};
    const until = cooldowns[venueId];
    if (!until || !State.variables.gameDate) { return 0; }
    return Math.max(0, Math.ceil((new Date(until).getTime() - State.variables.gameDate.getTime()) / 60000));
};

setup.setVenueAccessPending = function (venueId) {
    State.variables.venueAccessPending = venueId;
};

setup.setVenueAttemptCooldown = function (venueId) {
    const rule = setup.getVenueAccessRule(venueId);
    const lockpick = rule && rule.lockpick;
    if (!lockpick) { return; }
    const cooldowns = State.variables.venueAccessCooldowns || (State.variables.venueAccessCooldowns = {});
    cooldowns[venueId] = new Date(State.variables.gameDate.getTime() + lockpick.attemptCooldownMinutes * 60 * 1000);
};

setup.setVenueLockedOutToday = function (venueId) {
    const lockouts = State.variables.venueDailyLockouts || (State.variables.venueDailyLockouts = {});
    lockouts[venueId] = setup.getGameDateKey();
};

setup.getLockpickChance = function (venueId) {
    const rule = setup.getVenueAccessRule(venueId);
    const lockpick = rule && rule.lockpick;
    const state = State.variables;
    if (!lockpick) { return 0; }
    const chance = lockpick.baseChance + state.skills.dexterity.level * lockpick.dexterityLevelWeight + setup.getEffectiveLuck() * lockpick.luckWeight - lockpick.difficulty;
    return Math.max(lockpick.minimumChance, Math.min(lockpick.maximumChance, chance));
};

setup.getGuardCatchChance = function (venueId) {
    const rule = setup.getVenueAccessRule(venueId);
    const lockpick = rule && rule.lockpick;
    const state = State.variables;
    if (!lockpick) { return 0; }
    const chance = lockpick.guardBaseChance - state.skills.dexterity.level * lockpick.guardDexterityReductionPerLevel - setup.getEffectiveLuck() * lockpick.guardLuckReduction;
    return Math.max(lockpick.guardMinimumChance, Math.min(lockpick.guardMaximumChance, chance));
};

setup.t = function (path, fallback) {
    const database = setup.gameDatabase;
    const language = State.variables.language || database.defaultLanguage;
    let value = database.locales[language] || database.locales[database.defaultLanguage];
    for (const key of path.split(".")) {
        value = value && value[key];
    }
    return value === undefined ? (fallback || path) : value;
};

setup.itemText = function (itemId, field) {
    return setup.t("items." + itemId + "." + field);
};

/* NPC 的顯示文字與代表色。新增角色時，在 locales.npcs 和 npcs 內補上同一個 ID。 */
setup.npcText = function (npcId, field) {
    return setup.t("npcs." + npcId + "." + field);
};

setup.npcColor = function (npcId) {
    const npc = setup.gameDatabase.npcs[npcId];
    return (npc && npc.color) || "#ffffff";
};

/*
    依 NPC 資料庫產生對應的 CSS 類別，例如 .npc-winley。
    不需要在 Stylesheet 重複填色碼，修改上方 npcs 的 color 就會一併更新所有台詞。
*/
setup.installNpcColorClasses = function () {
    const styleId = "npc-color-classes";
    let style = document.getElementById(styleId);
    if (!style) {
        style = document.createElement("style");
        style.id = styleId;
        document.head.appendChild(style);
    }
    style.textContent = Object.entries(setup.gameDatabase.npcs)
        .filter(function (entry) { return entry[1].tags.includes("named_npc"); })
        .map(function (entry) {
            return ".npc-" + entry[0] + " { color: " + entry[1].color + "; font-weight: bold; }";
        })
        .join("\n");
};

setup.installNpcColorClasses();

setup.getShopItems = function (shopId) {
    return setup.gameDatabase.shops[shopId].itemIds.map(function (id) {
        return Object.assign({ id: id }, setup.gameDatabase.items[id]);
    });
};

setup.getCartTotal = function (shopId) {
    const cart = State.variables.cart || {};
    return setup.getShopItems(shopId).reduce(function (total, item) {
        const quantity = Math.max(0, Math.floor(Number(cart[item.id]) || 0));
        return total + quantity * item.price;
    }, 0);
};

setup.initializeGameDatabaseState = function () {
    const state = State.variables;
    state.language = setup.gameDatabase.defaultLanguage;
    state.inventory = {};
    state.cart = {};
    Object.keys(setup.gameDatabase.items).forEach(function (itemId) {
        state.inventory[itemId] = 0;
        state.cart[itemId] = 0;
    });
    state.inventoryMessage = "";
    state.timedEffects = {};
    state.knownNpcs = [];
    state.playerTags = [];
    state.rentDebt = 0;
    state.rentGraceDeadline = null;
    state.rentNextAffectionPenaltyAt = null;
    state.housingStatus = "housed";
    state.reputationEvictionTriggered = false;
    state.rentEventPending = null;
    state.npcRelations = {};
    Object.keys(setup.gameDatabase.npcs).forEach(function (npcId) {
        const relation = setup.gameDatabase.npcs[npcId].relationship;
        state.npcRelations[npcId] = { affection: relation.affectionStart || 0 };
        if (relation.romanceEnabled) {
            state.npcRelations[npcId].romance = relation.romanceStart || 0;
        }
    });
    state.flags = {};
};

/*
    舊存檔補值：只補「不存在」的欄位，絕不覆蓋玩家原有進度。
    之後新增新的存檔變數時，請把預設值加在這裡，並將 saveVersion 加 1。
*/
setup.ensureGameState = function () {
    const state = State.variables;
    const balance = setup.balance;
    const statDefaults = balance.player.stats;

    Object.keys(statDefaults).forEach(function (stat) {
        const definition = statDefaults[stat];
        if (state[stat] === undefined) { state[stat] = definition.start; }
        if (state[stat + "Max"] === undefined) { state[stat + "Max"] = definition.max; }
    });

    if (state.money === undefined) { state.money = balance.player.startMoney; }
    state.money = Math.max(0, Number(state.money) || 0);
    if (state.rentDebt === undefined) { state.rentDebt = 0; }
    if (state.rentGraceDeadline === undefined) { state.rentGraceDeadline = null; }
    if (state.rentNextAffectionPenaltyAt === undefined) { state.rentNextAffectionPenaltyAt = null; }
    if (state.housingStatus === undefined) { state.housingStatus = "housed"; }
    if (state.reputationEvictionTriggered === undefined) { state.reputationEvictionTriggered = false; }
    if (state.rentEventPending === undefined) { state.rentEventPending = null; }
    if (state.language === undefined) { state.language = setup.gameDatabase.defaultLanguage; }
    if (state.skillMaxLevel === undefined) { state.skillMaxLevel = balance.skills.maxLevel; }
    if (state.gymMember === undefined) { state.gymMember = false; }
    if (state.gymExpiry === undefined) { state.gymExpiry = null; }
    if (state.energyBuffer === undefined) { state.energyBuffer = 0; }
    if (state.hygieneBuffer === undefined) { state.hygieneBuffer = 0; }
    if (state.satietyBuffer === undefined) { state.satietyBuffer = 0; }
    if (state.hornyBuffer === undefined) { state.hornyBuffer = 0; }
    if (state.timedEffects === undefined) { state.timedEffects = {}; }
    if (state.robberEventCooldownUntil === undefined) { state.robberEventCooldownUntil = null; }
    if (state.convenienceRobberyCooldownUntil === undefined) { state.convenienceRobberyCooldownUntil = null; }
    if (state.venueAccessDenied === undefined) { state.venueAccessDenied = null; }
    if (state.venueAccessPending === undefined) { state.venueAccessPending = null; }
    if (state.venueDailyLockouts === undefined) { state.venueDailyLockouts = {}; }
    if (state.venueAccessCooldowns === undefined) { state.venueAccessCooldowns = {}; }
    if (state.playerGender === undefined) { state.playerGender = null; }
    if (state.majorId === undefined) { state.majorId = null; }
    if (state.majorChangeAvailableAt === undefined) {
        const waitDays = setup.gameDatabase.venueRules.university.education.majorChangeWaitDays;
        state.majorChangeAvailableAt = state.gameDate ? new Date(state.gameDate.getTime() + (waitDays * 24 * 60 * 60 * 1000)) : null;
    }
    if (state.faintEventActive === undefined) { state.faintEventActive = false; }
    if (state.faintedAtHome === undefined) { state.faintedAtHome = false; }
    if (state.cheatsEnabled === undefined) { state.cheatsEnabled = false; }
    if (state.saveVersion === undefined) { state.saveVersion = balance.saveVersion; }

    if (state.inventory === undefined) { state.inventory = {}; }
    if (state.cart === undefined) { state.cart = {}; }
    Object.keys(setup.gameDatabase.items).forEach(function (itemId) {
        if (state.inventory[itemId] === undefined) { state.inventory[itemId] = 0; }
        if (state.cart[itemId] === undefined) { state.cart[itemId] = 0; }
    });

    if (state.knownNpcs === undefined) { state.knownNpcs = []; }
    if (state.playerTags === undefined) { state.playerTags = []; }
    /* 舊存檔曾以中文儲存無家可歸標籤，讀檔時轉為一致的英文 ID。 */
    if (state.playerTags.includes("無家可歸")) {
        state.playerTags = state.playerTags.filter(function (tag) { return tag !== "無家可歸"; });
        if (!state.playerTags.includes("homeless")) { state.playerTags.push("homeless"); }
    }
    if (state.flags === undefined) { state.flags = {}; }
    if (state.npcRelations === undefined) { state.npcRelations = {}; }
    Object.keys(setup.gameDatabase.npcs).forEach(function (npcId) {
        const relation = setup.gameDatabase.npcs[npcId].relationship;
        if (state.npcRelations[npcId] === undefined) {
            state.npcRelations[npcId] = { affection: relation.affectionStart || 0 };
        }
        if (relation.romanceEnabled && state.npcRelations[npcId].romance === undefined) {
            state.npcRelations[npcId].romance = relation.romanceStart || 0;
        }
        state.npcRelations[npcId].affection = Math.clamp(Number(state.npcRelations[npcId].affection) || 0, -100, 100);
    });
};

/* 好感度的合法範圍為 -100～100；負數可用於厭惡與仇人關係。 */
setup.changeNpcAffection = function (npcId, amount) {
    const relation = State.variables.npcRelations && State.variables.npcRelations[npcId];
    if (!relation) { return false; }
    relation.affection = Math.clamp((Number(relation.affection) || 0) + (Number(amount) || 0), -100, 100);
    return true;
};

setup.getNpcRelationTier = function (affection) {
    const value = Math.clamp(Number(affection) || 0, -100, 100);
    if (value <= -80) { return "仇人"; }
    if (value <= -10) { return "厭惡"; }
    return "普通";
};

/* 每次進入故事前安全補齊舊存檔缺少的欄位。 */
jQuery(document).on(":passagestart.ensureGameState", function () {
    setup.ensureGameState();
});

/* 已認識 NPC 是存檔狀態；同一角色不會重複加入。 */
setup.meetNpc = function (npcId) {
    const npc = setup.gameDatabase.npcs[npcId];
    const knownNpcs = State.variables.knownNpcs || (State.variables.knownNpcs = []);
    if (!npc || !npc.tags.includes("named_npc") || knownNpcs.includes(npcId)) { return false; }
    knownNpcs.push(npcId);
    return true;
};

/* 玩家身分標籤；可用於工作、組織或劇情資格判定。 */
setup.playerHasTag = function (tag) {
    return (State.variables.playerTags || []).includes(tag);
};

setup.addPlayerTag = function (tag) {
    const tags = State.variables.playerTags || (State.variables.playerTags = []);
    if (tags.includes(tag)) { return false; }
    tags.push(tag);
    return true;
};

/* 移除可逆的玩家身分／狀態，例如辭職或重新取得住處。 */
setup.removePlayerTag = function (tag) {
    const tags = State.variables.playerTags || (State.variables.playerTags = []);
    const index = tags.indexOf(tag);
    if (index === -1) { return false; }
    tags.splice(index, 1);
    return true;
};

setup.npcSocialInfo = function (npcId) {
    const npc = setup.gameDatabase.npcs[npcId];
    return (npc && npc.social) || {};
};

setup.inventoryCount = function () {
    return Object.values(State.variables.inventory || {}).reduce(function (total, quantity) {
        return total + Math.max(0, Number(quantity) || 0);
    }, 0);
};

setup.useItem = function (itemId) {
    const item = setup.gameDatabase.items[itemId];
    const state = State.variables;
    const inventory = state.inventory || (state.inventory = {});
    if (!item || !inventory[itemId]) { return false; }

    /* 同一種限時效果不疊加；效果持續時再次使用不消耗物品。 */
    const timedEffect = item.effects.find(function (effect) { return effect.type === "timedStat"; });
    if (timedEffect && state.timedEffects && state.timedEffects[timedEffect.effectId]) {
        state.inventoryMessage = "袋裝「二手幸運」的效果仍在持續中。";
        return false;
    }

    inventory[itemId] -= 1;
    item.effects.forEach(function (effect) {
        if (effect.type === "stat") {
            const max = state[effect.stat + "Max"];
            state[effect.stat] = Math.min(max, Math.max(0, state[effect.stat] + effect.amount));
        }
        if (effect.type === "timedStat") {
            const timedEffects = state.timedEffects || (state.timedEffects = {});
            const originalValue = state[effect.stat];
            const max = state[effect.stat + "Max"];
            timedEffects[effect.effectId] = {
                itemId: itemId,
                stat: effect.stat,
                amount: effect.amount,
                originalValue: originalValue,
                expireAmount: effect.expireAmount,
                debuffDurationMinutes: effect.debuffDurationMinutes,
                phase: "buff",
                expiresAt: new Date(state.gameDate.getTime() + effect.durationMinutes * 60 * 1000)
            };
            state[effect.stat] = Math.min(max, Math.max(0, originalValue + effect.amount));
        }
    });
    state.inventoryMessage = setup.itemText(itemId, "useMessage");
    if (itemId === "ramen") {
        state.inventoryMessage += " 目前飽食度：" + Math.round(state.satiety) + " / " + Math.round(state.satietyMax) + "。";
    }
    return true;
};

/* 供左側狀態欄顯示目前套用中的限時 BUFF／DEBUFF。 */
setup.getTimedEffectStatus = function () {
    const state = State.variables;
    const effects = state.timedEffects || {};
    const statNames = { luck: "幸運", mood: "心情", hp: "體力", satiety: "飢餓" };

    return Object.keys(effects).map(function (effectId) {
        const effect = effects[effectId];
        const isDebuff = effect.phase === "debuff";
        const amount = isDebuff ? effect.expireAmount : (effect.amount !== undefined ? effect.amount : Math.abs(effect.expireAmount || 0));
        const remainingMinutes = Math.max(0, Math.ceil((new Date(effect.expiresAt).getTime() - state.gameDate.getTime()) / 60000));
        const itemName = setup.itemText(effect.itemId || effectId, "name");
        const sign = amount > 0 ? "+" : "";
        const phaseLabel = isDebuff ? "DEBUFF" : "BUFF";

        return itemName + "：" + phaseLabel + "，" + (statNames[effect.stat] || effect.stat) + " " + sign + amount + "（剩餘 " + remainingMinutes + " 分鐘）";
    });
};

/*
    背包是彈出視窗，不透過 passage 轉場；使用物品後只重繪視窗中的內容，
    避免 SugarCube 的 replace 巨集重建整個彈窗而造成版面跳動。
*/
setup.refreshInventoryDialog = function () {
    const target = document.querySelector("#ui-dialog-body.inventory-dialog #inventory-content");
    if (!target) { return; }
    jQuery(target).empty();
    new Wikifier(target, Story.get("背包內容").processText());
};

setup.refreshStoryCaption = function () {
    const target = document.getElementById("story-caption");
    if (!target) { return; }
    jQuery(target).empty();
    new Wikifier(target, Story.get("StoryCaption").processText());
};

jQuery(document).off("click.inventoryUse", "#ui-dialog-body.inventory-dialog .inventory-use-button");
jQuery(document).on("click.inventoryUse", "#ui-dialog-body.inventory-dialog .inventory-use-button", function (event) {
    event.preventDefault();
    setup.useItem(this.getAttribute("data-item-id"));
    setup.refreshInventoryDialog();
    setup.refreshStoryCaption();
});

setup.checkout = function (shopId) {
    const state = State.variables;
    const total = setup.getCartTotal(shopId);
    if (total <= 0 || state.money < total) { return false; }
    setup.getShopItems(shopId).forEach(function (item) {
        const quantity = Math.max(0, Math.floor(Number(state.cart[item.id]) || 0));
        /* 舊存檔可能沒有後來新增物品的欄位，先以 0 初始化再加入數量。 */
        state.inventory[item.id] = (state.inventory[item.id] || 0) + quantity;
        state.cart[item.id] = 0;
    });
    state.money -= total;
    return true;
};

/* 通用條件檢查器：供未來任務、對話與事件資料直接使用。 */
setup.conditionMet = function (condition) {
    const state = State.variables;
    if (condition.type === "npcHasTag") {
        return setup.gameDatabase.npcs[condition.npcId].tags.includes(condition.tag);
    }
    if (condition.type === "npcLacksTag") {
        return !setup.gameDatabase.npcs[condition.npcId].tags.includes(condition.tag);
    }
    if (condition.type === "hasItem") {
        return (state.inventory[condition.itemId] || 0) >= (condition.quantity || 1);
    }
    if (condition.type === "itemHasTag") {
        return setup.gameDatabase.items[condition.itemId].tags.includes(condition.tag);
    }
    if (condition.type === "relationshipAtLeast") {
        return state.npcRelations[condition.npcId][condition.stat] >= condition.value;
    }
    if (condition.type === "flag") {
        return state.flags[condition.flag] === (condition.value === undefined ? true : condition.value);
    }
    if (condition.type === "locationNotTagged") {
        return !tags().includes(condition.tag);
    }
    return false;
};
