        },
        recycled_luck_pouch: {
            icon: "🧧", category: "consumable", tags: ["consumable", "buff", "debuff", "temporary", "shop_cornerstore"],
            price: 100, stackable: true, usable: true,
            /* 到期時以 originalValue + expireAmount 結算，不會以加成後的數值為基礎。 */
            effects: [{ type: "timedStat", stat: "luck", amount: 30, durationMinutes: 120, expireAmount: -30, debuffDurationMinutes: 120, effectId: "recycled_luck_pouch" }]
        }
    },

    /*
        角色定義與「存檔中的關係數值」分開。tags 可用於事件條件，
        例如 { type: "npcHasTag", npcId: "alice", tag: "loyal" }。
    */
    npcs: {
        alice: {
            color: "#E88BA7",
            tags: ["named_npc", "romanceable", "loyal", "relationship_sensitive", "draft"],
            gender: null, birthday: null, likes: ["tea", "kindness"], dislikes: [],
